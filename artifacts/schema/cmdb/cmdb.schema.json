{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://espedair.io/schema/template/cmdb",
  "title": "CMDB Schema",
  "description": "Schema for configuration management data covering systems, databases, owners, and their relationships.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "owners",
    "systems",
    "databases"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional self-reference to this schema file."
    },
    "name": {
      "type": "string",
      "description": "Logical name of the CMDB package."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9._-]+)?$",
      "description": "Semantic version of the CMDB package."
    },
    "description": {
      "type": "string",
      "description": "Business and technical scope of this CMDB snapshot."
    },
    "source": {
      "type": "string",
      "description": "Source process or system used to derive this CMDB artifact."
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when the CMDB artifact was generated."
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "description": "People or teams accountable for systems and databases.",
      "items": {
        "$ref": "#/$defs/Owner"
      }
    },
    "systems": {
      "type": "array",
      "minItems": 1,
      "description": "Application and platform systems tracked in the CMDB.",
      "items": {
        "$ref": "#/$defs/System"
      }
    },
    "databases": {
      "type": "array",
      "minItems": 1,
      "description": "Databases that support tracked systems.",
      "items": {
        "$ref": "#/$defs/Database"
      }
    },
    "relationships": {
      "type": "array",
      "description": "Optional explicit links between CMDB entities for richer topology and dependency modeling.",
      "items": {
        "$ref": "#/$defs/Relationship"
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional summary statistics for the CMDB snapshot.",
      "properties": {
        "owner_count": {
          "type": "integer",
          "minimum": 0
        },
        "system_count": {
          "type": "integer",
          "minimum": 0
        },
        "database_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_system_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_database_count": {
          "type": "integer",
          "minimum": 0
        },
        "relationship_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "Owner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_id",
        "name",
        "owner_type",
        "status"
      ],
      "properties": {
        "owner_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$",
          "description": "Stable owner identifier used by systems and databases."
        },
        "name": {
          "type": "string",
          "description": "Display name of owner or owning team."
        },
        "owner_type": {
          "type": "string",
          "enum": [
            "person",
            "team",
            "service-owner",
            "platform-owner",
            "vendor",
            "custom"
          ],
          "description": "Owner classification."
        },
        "email": {
          "type": "string",
          "description": "Primary contact email for the owner."
        },
        "group": {
          "type": "string",
          "description": "Organization group or department for the owner."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive"
          ],
          "description": "Current owner status."
        },
        "description": {
          "type": "string",
          "description": "Additional context for the owner."
        }
      }
    },
    "System": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_id",
        "system_name",
        "owner_id",
        "system_layer",
        "environment",
        "status"
      ],
      "properties": {
        "system_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$",
          "description": "Stable unique system identifier."
        },
        "parent_system_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$",
          "description": "Optional parent system identifier for hierarchy drill-down. Must match another systems.system_id when provided."
        },
        "system_name": {
          "type": "string",
          "description": "Human-readable system name."
        },
        "owner_id": {
          "type": "string",
          "description": "Owner reference. Must match an owners.owner_id value."
        },
        "system_layer": {
          "type": "string",
          "enum": [
            "application",
            "ui",
            "middleware",
            "database",
            "integration",
            "batch",
            "platform",
            "other"
          ],
          "description": "System role/layer used to model parent-child architecture."
        },
        "criticality": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "description": "Operational criticality of the system."
        },
        "environment": {
          "type": "string",
          "enum": [
            "dev",
            "test",
            "uat",
            "prod",
            "shared",
            "unknown"
          ],
          "description": "Primary environment for this system record."
        },
        "lifecycle_stage": {
          "type": "string",
          "enum": [
            "plan",
            "build",
            "operate",
            "decommission",
            "unknown"
          ],
          "description": "Lifecycle stage of the system."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive",
            "retired"
          ],
          "description": "Operational status of the system."
        },
        "hosting_platform": {
          "type": "string",
          "description": "Hosting platform such as Azure, AWS, on-prem, or SaaS."
        },
        "interface_type": {
          "type": "string",
          "enum": [
            "api",
            "batch",
            "event",
            "file",
            "interactive",
            "mixed",
            "unknown"
          ],
          "description": "Primary interface mode exposed by the system."
        },
        "description": {
          "type": "string",
          "description": "Business and technical description of the system."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional labels for discovery and filtering."
        }
      }
    },
    "Relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relationship_id",
        "source_type",
        "source_id",
        "relationship_type",
        "target_type",
        "target_id",
        "status"
      ],
      "properties": {
        "relationship_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$",
          "description": "Stable unique relationship identifier."
        },
        "source_type": {
          "type": "string",
          "enum": [
            "owner",
            "system",
            "database"
          ],
          "description": "Entity type at the source side of the relationship."
        },
        "source_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$",
          "description": "Identifier of the source entity."
        },
        "relationship_type": {
          "type": "string",
          "enum": [
            "depends-on",
            "calls",
            "publishes-to",
            "reads-from",
            "writes-to",
            "hosts",
            "supports",
            "owns",
            "contains",
            "replicates-to",
            "other"
          ],
          "description": "Typed semantic link between source and target entities."
        },
        "target_type": {
          "type": "string",
          "enum": [
            "owner",
            "system",
            "database"
          ],
          "description": "Entity type at the target side of the relationship."
        },
        "target_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$",
          "description": "Identifier of the target entity."
        },
        "direction": {
          "type": "string",
          "enum": [
            "unidirectional",
            "bidirectional"
          ],
          "description": "Directionality of the relationship."
        },
        "criticality": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "description": "Operational criticality of this relationship."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive",
            "retired"
          ],
          "description": "Current status of the relationship."
        },
        "description": {
          "type": "string",
          "description": "Optional narrative about the relationship purpose or constraints."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional labels for filtering and discovery."
        }
      }
    },
    "Database": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "database_id",
        "database_name",
        "system_id",
        "owner_id",
        "engine",
        "environment",
        "status"
      ],
      "properties": {
        "database_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$",
          "description": "Stable unique database identifier."
        },
        "database_name": {
          "type": "string",
          "description": "Human-readable or physical database name."
        },
        "system_id": {
          "type": "string",
          "description": "Owning or primary consuming system identifier. Must match systems.system_id."
        },
        "owner_id": {
          "type": "string",
          "description": "Owner reference. Must match owners.owner_id."
        },
        "engine": {
          "type": "string",
          "enum": [
            "sqlite",
            "postgresql",
            "mysql",
            "sqlserver",
            "oracle",
            "db2",
            "snowflake",
            "bigquery",
            "mongodb",
            "redshift",
            "custom"
          ],
          "description": "Database engine or platform."
        },
        "engine_version": {
          "type": "string",
          "description": "Version of the database engine when known."
        },
        "environment": {
          "type": "string",
          "enum": [
            "dev",
            "test",
            "uat",
            "prod",
            "shared",
            "unknown"
          ],
          "description": "Environment where the database is hosted."
        },
        "classification": {
          "type": "string",
          "enum": [
            "Public",
            "Internal",
            "Confidential",
            "Highly Confidential",
            "Restricted"
          ],
          "description": "Information classification for data stored in this database."
        },
        "lifecycle_stage": {
          "type": "string",
          "enum": [
            "plan",
            "build",
            "operate",
            "decommission",
            "unknown"
          ],
          "description": "Lifecycle stage of the database."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive",
            "retired"
          ],
          "description": "Operational status of the database."
        },
        "backup_policy": {
          "type": "string",
          "description": "Reference to backup policy or backup SLA."
        },
        "rpo": {
          "type": "string",
          "description": "Recovery point objective for the database."
        },
        "rto": {
          "type": "string",
          "description": "Recovery time objective for the database."
        },
        "description": {
          "type": "string",
          "description": "Business and technical description of the database."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional labels for discovery and filtering."
        }
      }
    }
  }
}
