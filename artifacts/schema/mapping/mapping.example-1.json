  "transformation_definitions": [
    {
      "transformation_id": "tr.normalize_email",
      "type": "expression",
      "expression": "LOWER(TRIM(email_address))",
      "language": "sql",
      "description": "Normalize email string for consistent matching"
    },
    {
      "transformation_id": "tr.full_name",
      "type": "concat",
      "expression": "CONCAT(first_name, ' ', last_name)",
      "language": "sql",
      "description": "Build full name from first and last name"
    },
    {
      "transformation_id": "tr.customer_status",
      "type": "conditional",
      "expression": "CASE WHEN is_active = 1 THEN 'ACTIVE' ELSE 'INACTIVE' END",
      "language": "sql",
      "description": "Standardize active status values"
    }
  ],
  "rule_definitions": [
    {
      "rule_id": "rule.email_format",
      "rule_type": "validation",
      "severity": "high",
      "expression": "email_address LIKE '%@%'",
      "description": "Email must include @ symbol"
    },
    {
      "rule_id": "rule.customer_id_not_null",
      "rule_type": "quality",
      "severity": "critical",
      "expression": "customer_id IS NOT NULL",
      "description": "Customer id is mandatory"
    },
    {
      "rule_id": "rule.filter_deleted",
      "rule_type": "filter",
      "severity": "medium",
      "expression": "is_deleted = 0",
      "description": "Exclude deleted source records"
    }
  ],
  "mapping_sets": [
    {
      "mapping_id": "map.customer_master_consolidation",
      "mapping_name": "CRM and KYC to Customer Master",
      "mapping_type": "many-to-one",
      "description": "Consolidates CRM and KYC source records into a single unified customer master target.",
      "sources": [
        {
          "table_id": "src.crm_customer",
          "table_name": "crm.customer",
          "alias": "c",
          "filter": "c.is_deleted = 0"
        },
        {
          "table_id": "src.kyc_profile",
          "table_name": "kyc.profile",
          "alias": "k",
          "filter": "k.record_status = 'CURRENT'"
        }
      ],
      "targets": [
        {
          "table_id": "tgt.customer_master",
          "table_name": "udp_gold.customer_master",
          "write_mode": "merge"
        }
      ],
      "join_definitions": [
        {
          "left_table_id": "src.crm_customer",
          "right_table_id": "src.kyc_profile",
          "join_type": "left",
          "condition": "c.customer_id = k.customer_id"
        }
      ],
      "column_mappings": [
