          ],
          "nullable": true,
          "default_value": "unknown@example.com",
          "description": "Normalized customer email"
        },
        {
          "target_table_id": "tgt.customer_master",
          "target_column": "customer_status",
          "target_data_type": "STRING",
          "mapping_mode": "conditional",
          "source_columns": [
            {
              "table_id": "src.crm_customer",
              "column": "is_active"
            }
          ],
          "transformation_ref": "tr.customer_status",
          "nullable": false,
          "default_value": "INACTIVE",
          "description": "Standardized customer status"
        },
        {
          "target_table_id": "tgt.customer_master",
          "target_column": "record_source",
          "target_data_type": "STRING",
          "mapping_mode": "constant",
