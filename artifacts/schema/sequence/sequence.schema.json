{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://espedair.io/schema/template/sequence",
  "title": "Sequence Diagram Data Schema",
  "description": "Schema for sequence diagram data with participants, ordered messages, control fragments, and governance metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "participants",
    "messages"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional self-reference to this schema file."
    },
    "name": {
      "type": "string",
      "description": "Logical name of the sequence scenario."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9._-]+)?$",
      "description": "Semantic version of the sequence model."
    },
    "title": {
      "type": "string",
      "description": "Human-readable title for the scenario."
    },
    "description": {
      "type": "string",
      "description": "Business or technical description of sequence scope."
    },
    "scenario_type": {
      "type": "string",
      "enum": [
        "business",
        "system",
        "api",
        "integration",
        "incident",
        "reconciliation",
        "custom"
      ],
      "description": "Classification of the sequence scenario."
    },
    "source": {
      "type": "string",
      "description": "Source note, runbook, specification, or extraction method."
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when the sequence data was generated."
    },
    "trigger": {
      "type": "string",
      "description": "Event that initiates the sequence."
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Conditions expected before execution."
    },
    "postconditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Expected outcomes after completion."
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": {
          "type": "string"
        },
        "steward": {
          "type": "string"
        },
        "approval_status": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "approved",
            "deprecated"
          ]
        },
        "approved_at": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Participant"
      },
      "description": "Participants represented as sequence lifelines."
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Message"
      },
      "description": "Ordered interactions between participants."
    },
    "fragments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Fragment"
      },
      "description": "Optional control fragments such as alt, loop, and par."
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Note"
      },
      "description": "Optional annotations for participants or sequence steps."
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "participant_count": {
          "type": "integer",
          "minimum": 0
        },
        "message_count": {
          "type": "integer",
          "minimum": 0
        },
        "fragment_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_parallel_branches": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "EvidenceAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "location",
        "detail"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "Participant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "participant_type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$"
        },
        "name": {
          "type": "string"
        },
        "participant_type": {
          "type": "string",
          "enum": [
            "actor",
            "role",
            "service",
            "system",
            "application",
            "database",
            "queue",
            "external",
            "custom"
          ]
        },
        "alias": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "classification": {
          "type": "string",
          "enum": [
            "Public",
            "Internal",
            "Confidential",
            "Highly Confidential",
            "Restricted"
          ]
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sequence",
        "from",
        "to",
        "message_type",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "message_type": {
          "type": "string",
          "enum": [
            "sync",
            "async",
            "reply",
            "create",
            "destroy",
            "self",
            "error",
            "custom"
          ]
        },
        "label": {
          "type": "string"
        },
        "operation": {
          "type": "string"
        },
        "payload_ref": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 0
        },
        "activates": {
          "type": "boolean"
        },
        "deactivates": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_anchors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceAnchor"
          }
        }
      }
    },
    "FragmentOperand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$"
        },
        "label": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "start_sequence": {
          "type": "integer",
          "minimum": 1
        },
        "end_sequence": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "Fragment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "fragment_type",
        "start_sequence",
        "end_sequence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$"
        },
        "fragment_type": {
          "type": "string",
          "enum": [
            "alt",
            "opt",
            "loop",
            "par",
            "break",
            "critical",
            "ref",
            "group",
            "custom"
          ]
        },
        "label": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "iteration": {
          "type": "string"
        },
        "start_sequence": {
          "type": "integer",
          "minimum": 1
        },
        "end_sequence": {
          "type": "integer",
          "minimum": 1
        },
        "participant_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FragmentOperand"
          }
        },
        "evidence_anchors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceAnchor"
          }
        }
      }
    },
    "Note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$"
        },
        "text": {
          "type": "string"
        },
        "placement": {
          "type": "string",
          "enum": [
            "left-of",
            "right-of",
            "over",
            "global"
          ]
        },
        "participant_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}