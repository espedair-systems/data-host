  "sites": [
    {
      "site_id": "site.regs-portal",
      "site_name": "Regulations Portal",
      "framework": "astro",
      "status": "active",
      "description": "Public-facing regulatory publication site for standards, schedules, and updates.",
      "repo": {
        "provider": "github",
        "full_name": "espedair/regs-system",
        "default_branch": "main",
        "path": "sites/regs-portal"
      },
      "domains": [
        {
          "host": "regs.example.com",
          "domain_type": "primary",
          "tls_mode": "managed"
        },
        {
          "host": "preview.regs.example.com",
          "domain_type": "preview",
          "tls_mode": "managed"
        }
      ],
      "build": {
        "node_version": "20.x",
        "package_manager": "pnpm",
        "install_command": "pnpm install --frozen-lockfile",
        "build_command": "pnpm run build",
        "output_mode": "static",
        "output_dir": "dist"
      },
      "deploy": {
        "target": "cloudflare-pages",
        "strategy": "branch-based",
        "preview_enabled": true,
        "artifact_retention_days": 30
      },
      "environments": [
        {
          "env_id": "env.regs.dev",
          "env_type": "dev",
          "base_url": "https://dev-regs.example.pages.dev",
          "branch": "develop",
          "env_var_refs": [
            "vault://web/dev/cms-token",
            "vault://web/dev/analytics-key"
          ],
          "status": "active"
        },
        {
          "env_id": "env.regs.prod",
          "env_type": "prod",
          "base_url": "https://regs.example.com",
          "branch": "main",
          "env_var_refs": [
            "vault://web/prod/cms-token",
            "vault://web/prod/analytics-key"
          ],
          "status": "active"
        }
      ],
      "content": {
        "collections": [
          {
            "collection_id": "regulations",
            "source": "mdx",
            "schema_mode": "strict",
            "content_path": "src/content/regulations"
          },
          {
            "collection_id": "notices",
            "source": "markdown",
            "schema_mode": "strict",
            "content_path": "src/content/notices"
          }
        ],
        "default_locale": "en-AU",
        "supported_locales": [
          "en-AU"
        ]
      },
      "integrations": [
        {
          "integration_id": "int.astro.sitemap",
          "name": "@astrojs/sitemap",
          "integration_type": "astro",
          "config_ref": "astro.config.mjs#sitemap",
          "status": "active"
        },
        {
          "integration_id": "int.search.algolia",
          "name": "Algolia Search",
          "integration_type": "search",
          "config_ref": "infra/search/algolia-regs.json",
          "status": "active"
        },
        {
          "integration_id": "int.analytics.ga4",
          "name": "Google Analytics 4",
          "integration_type": "analytics",
          "config_ref": "vault://web/prod/ga4-measurement-id",
          "status": "active"
        }
      ],
      "security": {
        "auth_mode": "none",
        "waf_enabled": true,
        "headers_policy_ref": "policy://web/security/headers-v3"
      },
      "observability": {
        "analytics_provider": "GA4",
        "logging_sink": "Azure Log Analytics",
        "uptime_monitor_ref": "monitor://web/regs-portal-uptime"
      },
      "tags": [
        "regulatory",
        "public",
        "astro"
      ]
    },
    {
