          "status": "active"
        }
      ],
      "security": {
        "auth_mode": "oidc",
        "waf_enabled": true,
        "headers_policy_ref": "policy://web/security/internal-headers-v2"
      },
      "observability": {
        "analytics_provider": "Internal Insights",
        "logging_sink": "Azure Monitor",
        "uptime_monitor_ref": "monitor://web/docs-hub-uptime"
      },
      "tags": [
