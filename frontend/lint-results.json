ringify(preferredCategories));\n    }, [preferredCategories]);\n\n    return (\n        <DirectoryPreferenceContext.Provider value={{ preferredCategories, setPreferredCategories, allCategories }}>\n            {children}\n        </DirectoryPreferenceContext.Provider>\n    );\n};\n\nexport const useDirectoryPreferences = () => {\n    const context = useContext(DirectoryPreferenceContext);\n    if (!context) {\n        throw new Error('useDirectoryPreferences must be used within a DirectoryPreferenceProvider');\n    }\n    return context;\n};\n","usedDeprecatedRules":[]},{"filePath":"/run/media/jonk/Workspace/astro/espedair/data-host/frontend/src/lib/utils.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/run/media/jonk/Workspace/astro/espedair/data-host/frontend/src/main.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/run/media/jonk/Workspace/astro/espedair/data-host/frontend/src/pages/AWSPlatform.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/run/media/jonk/Workspace/astro/espedair/data-host/frontend/src/pages/BigQueryDashboard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/run/media/jonk/Workspace/astro/espedair/data-host/frontend/src/pages/BigQueryIngestion.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/run/media/jonk/Workspace/astro/espedair/data-host/frontend/src/pages/Config.tsx","messages":[],"suppressedMes