# Server Configuration
# Configuration
CONFIG_FILE=config.yaml

# Server Configuration
DATA_HOST_PORT=8080
DATA_HOST_FRONTEND_PATH=./frontend/dist
DATA_HOST_DATA_PATH=/

# Database
DATA_HOST_DATABASE_URL=blueprint.db

# Logging Configuration
DATA_HOST_DEBUG=true                    # Development mode with pretty output
DATA_HOST_LOG_LEVEL=DEBUG               # DEBUG, INFO, WARN, ERROR, FATAL
DATA_HOST_LOG_FORMAT=pretty             # pretty or json
DATA_HOST_LOG_OUTPUT=stdout             # stdout or file path

# Migration Configuration
MIGRATE_ON_STARTUP=true                 # Run migrations when server starts

# Security Configuration
CORS_ALLOW_ORIGINS="http://localhost:5173,http://localhost:8080"
RATE_LIMIT_READ=100
RATE_LIMIT_WRITE=10
JWT_SECRET="your-very-secure-secret-key-at-least-32-chars"
