        "font-weight": "bold",
        "color": "white"
      }
    },
    {
      "selector": "node[type='org_unit'][unitType='division']",
      "style": {
        "background-color": "#2ca02c",
        "label": "data(name)",
        "shape": "rectangle",
        "text-halign": "center",
        "text-valign": "center",
        "font-size": 12,
        "color": "white"
      }
    },
    {
      "selector": "node[type='org_unit'][unitType='department']",
      "style": {
        "background-color": "#ff7f0e",
        "label": "data(name)",
        "shape": "rectangle",
        "text-halign": "center",
        "text-valign": "center",
        "font-size": 11,
        "color": "white"
      }
    },
    {
      "selector": "node[type='org_unit'][unitType='team']",
      "style": {
        "background-color": "#d62728",
        "label": "data(name)",
        "shape": "rectangle",
        "text-halign": "center",
        "text-valign": "center",
        "font-size": 10,
        "color": "white"
      }
    },
    {
      "selector": "node[type='position']",
      "style": {
        "background-color": "#9467bd",
        "label": "data(title)",
        "shape": "diamond",
        "text-halign": "center",
        "text-valign": "center",
        "font-size": 10,
        "color": "white"
      }
    },
    {
      "selector": "node[type='person']",
      "style": {
        "background-color": "#17becf",
        "label": "data(displayName)",
        "shape": "ellipse",
        "text-halign": "center",
        "text-valign": "center",
        "font-size": 10,
        "color": "white"
      }
    },
    {
      "selector": "edge[type='unit_hierarchy']",
      "style": {
        "line-color": "#cccccc",
        "target-arrow-color": "#cccccc",
        "target-arrow-shape": "triangle-tee",
        "curve-style": "bezier",
        "arrow-scale": 1.5
      }
    },
    {
      "selector": "edge[type='position_in_unit']",
      "style": {
        "line-color": "#999999",
        "target-arrow-color": "#999999",
        "target-arrow-shape": "square",
        "curve-style": "bezier",
        "arrow-scale": 1.2
      }
    },
    {
      "selector": "edge[type='occupies_position']",
      "style": {
        "line-color": "#666666",
        "target-arrow-color": "#666666",
        "target-arrow-shape": "circle",
        "curve-style": "bezier",
        "arrow-scale": 1,
        "line-style": "dashed"
      }
    },
    {
      "selector": "edge[type='reports_to']",
      "style": {
        "line-color": "#ff0000",
        "target-arrow-color": "#ff0000",
        "target-arrow-shape": "triangle",
        "curve-style": "bezier",
        "arrow-scale": 1.5,
        "line-style": "solid",
        "width": 2
      }
    }
